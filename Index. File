<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Apex Build | Premium Construction Nairobi</title>
  <!-- Google Fonts & Font Awesome 6 -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', sans-serif;
      background-color: #FFFFFF;
      color: #1F2A3E;
      line-height: 1.5;
      scroll-behavior: smooth;
    }

    /* container */
    .container {
      width: 100%;
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    /* mobile-first spacing */
    section {
      padding: 3.5rem 0;
    }

    .section-title {
      font-size: 2rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      text-align: center;
      margin-bottom: 1rem;
    }

    .section-sub {
      text-align: center;
      max-width: 700px;
      margin: 0 auto 2.5rem auto;
      color: #5A6874;
      font-weight: 400;
    }

    /* buttons */
    .btn-primary {
      display: inline-block;
      background: #E67E22;
      color: white;
      font-weight: 700;
      padding: 0.9rem 2rem;
      border-radius: 40px;
      text-decoration: none;
      transition: all 0.25s ease;
      border: none;
      cursor: pointer;
      font-size: 1rem;
      text-align: center;
      box-shadow: 0 6px 14px rgba(230, 126, 34, 0.25);
    }

    .btn-primary:hover {
      background: #CF711F;
      transform: translateY(-3px);
      box-shadow: 0 12px 22px rgba(230, 126, 34, 0.3);
    }

    .btn-outline {
      background: transparent;
      border: 2px solid #E67E22;
      color: #E67E22;
      font-weight: 600;
      padding: 0.6rem 1.5rem;
      border-radius: 40px;
      transition: 0.2s;
      display: inline-block;
      text-decoration: none;
    }

    .btn-outline:hover {
      background: #E67E22;
      color: white;
    }

    /* navbar */
    .navbar {
      background: rgba(255, 255, 255, 0.96);
      backdrop-filter: blur(6px);
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
      padding: 1rem 0;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .nav-flex {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
    }
    .logo {
      font-size: 1.6rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      color: #1F2A3E;
    }
    .logo span {
      color: #E67E22;
    }
    .nav-links {
      display: flex;
      gap: 2rem;
      align-items: center;
    }
    .nav-links a {
      text-decoration: none;
      font-weight: 500;
      color: #2C3E50;
      transition: color 0.2s;
    }
    .nav-links a:hover {
      color: #E67E22;
    }

    /* hero */
    .hero {
      background: linear-gradient(105deg, #0B1A2E 0%, #13273F 100%), url('https://images.unsplash.com/photo-1541888946425-d81bb19240f5?w=1600&auto=format') center/cover no-repeat;
      background-blend-mode: overlay;
      background-size: cover;
      color: white;
      padding: 4rem 0 5rem;
    }
    .hero-content {
      max-width: 700px;
    }
    .hero h1 {
      font-size: 2.6rem;
      font-weight: 800;
      line-height: 1.2;
      margin-bottom: 1rem;
    }
    .hero p {
      font-size: 1.1rem;
      margin-bottom: 2rem;
      opacity: 0.9;
    }
    .hero-badge {
      background: rgba(230, 126, 34, 0.2);
      backdrop-filter: blur(4px);
      display: inline-block;
      padding: 0.3rem 1rem;
      border-radius: 40px;
      font-size: 0.8rem;
      font-weight: 600;
      margin-bottom: 1.2rem;
    }

    /* services grid */
    .services-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 2rem;
      margin-top: 1rem;
    }
    .service-card {
      background: #F9F9FC;
      padding: 1.8rem 1.2rem;
      border-radius: 28px;
      text-align: center;
      transition: all 0.2s;
      border: 1px solid #EFF0F4;
    }
    .service-card i {
      font-size: 2.3rem;
      color: #E67E22;
      margin-bottom: 1rem;
    }
    .service-card h3 {
      font-size: 1.3rem;
      margin-bottom: 0.5rem;
    }

    /* projects: previous + ongoing */
    .projects-previous-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 2rem;
    }
    .project-card {
      background: white;
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 12px 28px rgba(0, 0, 0, 0.05);
      transition: transform 0.2s;
    }
    .project-card img {
      width: 100%;
      height: 200px;
      object-fit: cover;
    }
    .project-info {
      padding: 1.2rem;
    }
    .project-info h4 {
      font-size: 1.2rem;
      font-weight: 700;
    }
    .project-info p {
      color: #5A6874;
      margin: 0.5rem 0;
    }

    /* ongoing projects */
    .ongoing-list {
      display: flex;
      flex-direction: column;
      gap: 1.8rem;
    }
    .ongoing-item {
      background: #FFFFFF;
      border-radius: 28px;
      padding: 1.2rem 1.5rem;
      box-shadow: 0 5px 16px rgba(0, 0, 0, 0.03);
      border: 1px solid #EAECF0;
    }
    .ongoing-header {
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      margin-bottom: 0.8rem;
    }
    .ongoing-title {
      font-weight: 800;
      font-size: 1.2rem;
    }
    .ongoing-location {
      color: #E67E22;
      font-weight: 500;
    }
    .progress-bar {
      background: #E9ECF0;
      border-radius: 40px;
      height: 8px;
      margin: 0.8rem 0;
      overflow: hidden;
    }
    .progress-fill {
      background: #E67E22;
      width: 0%;
      height: 100%;
      border-radius: 40px;
    }

    /* quotation & booking form */
    .quote-wrapper {
      background: linear-gradient(145deg, #F8FAFE, #FFFFFF);
      border-radius: 36px;
      padding: 2rem;
      box-shadow: 0 20px 35px -10px rgba(0, 0, 0, 0.05);
      border: 1px solid #EAEDF2;
      max-width: 900px;
      margin: 0 auto;
    }
    .form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.2rem;
    }
    .full-width {
      grid-column: span 2;
    }
    input, select, textarea {
      width: 100%;
      padding: 0.9rem 1rem;
      border-radius: 30px;
      border: 1px solid #D0D5DD;
      background: white;
      font-family: inherit;
      font-size: 0.95rem;
      transition: 0.2s;
    }
    input:focus, select:focus, textarea:focus {
      outline: none;
      border-color: #E67E22;
      box-shadow: 0 0 0 3px rgba(230, 126, 34, 0.1);
    }
    .quote-btn {
      width: 100%;
      background: #E67E22;
      font-weight: 700;
      padding: 1rem;
      font-size: 1.1rem;
    }
    .form-message {
      margin-top: 1.5rem;
      background: #EFF6F0;
      border-radius: 40px;
      padding: 0.8rem;
      text-align: center;
      font-weight: 500;
      display: none;
    }

    /* final CTA */
    .final-cta {
      background: linear-gradient(115deg, #0F2027, #203A43, #2C5364);
      color: white;
      text-align: center;
      border-radius: 48px;
      margin: 2rem 1.5rem 3rem;
      padding: 3rem 2rem;
    }
    .final-cta h2 {
      font-size: 2rem;
      font-weight: 800;
    }
    .final-cta .btn-primary {
      background: white;
      color: #E67E22;
      box-shadow: none;
      margin-top: 1.5rem;
    }
    .final-cta .btn-primary:hover {
      background: #FFF2E6;
    }

    footer {
      background: #11181C;
      color: #B0C4DE;
      padding: 2rem 0;
      text-align: center;
      font-size: 0.85rem;
    }

    /* responsive */
    @media (max-width: 768px) {
      .container {
        padding: 0 1.2rem;
      }
      .hero h1 {
        font-size: 2rem;
      }
      .section-title {
        font-size: 1.8rem;
      }
      .form-grid {
        grid-template-columns: 1fr;
        gap: 1rem;
      }
      .full-width {
        grid-column: span 1;
      }
      .nav-links {
        gap: 1rem;
        font-size: 0.85rem;
      }
      .final-cta {
        margin: 1.5rem 1rem 2rem;
        padding: 2rem 1rem;
      }
    }
    @media (max-width: 480px) {
      .nav-flex {
        flex-direction: column;
        gap: 0.7rem;
      }
    }
    .toast-notify {
      position: fixed;
      bottom: 25px;
      left: 50%;
      transform: translateX(-50%);
      background: #1F2A3E;
      color: white;
      padding: 0.8rem 1.8rem;
      border-radius: 60px;
      font-weight: 500;
      z-index: 200;
      display: flex;
      align-items: center;
      gap: 10px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.2);
      backdrop-filter: blur(8px);
    }
  </style>
</head>
<body>
  <nav class="navbar">
