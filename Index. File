    <!-- Booking Feature + Quotation Sessions (core interactive) -->
    <section id="quote" style="background: #FFFFFF;">
      <div class="container">
        <h2 class="section-title">Request a Quotation & Book Consultation</h2>
        <p class="section-sub">Tell us about your project — we'll prepare a detailed estimate and schedule a site meeting within 48 hours.</p>
        <div class="quote-wrapper">
          <form id="quoteForm">
            <div class="form-grid">
              <div><input type="text" id="fullName" placeholder="Full name *" required></div>
              <div><input type="email" id="email" placeholder="Email address *" required></div>
              <div><input type="tel" id="phone" placeholder="Phone number *" required></div>
              <div>
                <select id="projectType" required>
                  <option value="" disabled selected>Project type *</option>
                  <option>Residential Construction</option>
                  <option>Commercial Building</option>
                  <option>Renovation / Remodel</option>
                  <option>Interior Fit-out</option>
